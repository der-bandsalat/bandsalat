# --- Auth ---
# Beim allerersten Start (Users-Tabelle leer) wird ein Initial-Admin angelegt.
# Setze entweder APP_PASSWORD (Klartext, wird beim Seed gehasht) oder
# APP_PASSWORD_HASH (argon2id-Hash, bevorzugt). Username und E-Mail des
# Admins werden aus APP_ADMIN_USERNAME / APP_ADMIN_EMAIL gelesen (Defaults
# 'admin' / 'admin@bandsalat.local'). Nach dem ersten Login kannst du
# weitere User über /einstellungen/users anlegen — die Env-Variablen sind
# danach nicht mehr nötig (außer für Setup-Recovery).
APP_PASSWORD=dev-passwort-bitte-aendern
# APP_PASSWORD_HASH=$argon2id$v=19$m=65536,t=3,p=4$...
APP_ADMIN_USERNAME=admin
APP_ADMIN_EMAIL=admin@bandsalat.local

# Session-Cookie-Secret. >=32 Zeichen. Erzeugen mit:
#   openssl rand -hex 32
SESSION_SECRET=replace-with-openssl-rand-hex-32-chars-mindestens

# Cookie-Laufzeit in Tagen.
SESSION_DAYS=30

# --- Discogs ---
# Personal Access Token: discogs.com -> Settings -> Developers -> Generate token
DISCOGS_TOKEN=
DISCOGS_USERNAME=

# --- KI / Vision-Scan (optional) ---
# Anthropic Console -> API Keys: https://console.anthropic.com/settings/keys
# Wird nur für die Kamera-Erkennung in Quick-Add benötigt. Ohne Key ist die
# Funktion ausgeblendet und der Rest der App funktioniert normal weiter.
ANTHROPIC_API_KEY=
# Default-Modell: claude-haiku-4-5-20251001 (schnell+günstig, ~$0.001/Scan)
# Alternative: claude-sonnet-4-6 (~$0.01/Scan, robuster bei schwierigen Covern)
SCAN_MODEL=claude-haiku-4-5-20251001

# --- App ---
# Verzeichnis für SQLite-Datei und uploads/. In Docker auf ein Volume gemountet.
DATA_DIR=./data
PORT=3000
NODE_ENV=development

# Öffentliche Origin-URL (hinter Reverse-Proxy unverzichtbar — SvelteKit prüft
# Origin gegen diese für CSRF). Beispiel: https://bandsalat.example.com
ORIGIN=http://localhost:3000
